{
  "compilerOptions": {
    "types": ["node"],
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "NodeNext",
    "target": "es2022",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "nodenext"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
